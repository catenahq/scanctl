{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>catenahq/scanctl:secure-base"],
  "packageRules": [
    {
      "description": "Go module minor/patch: group + automerge after the shared cooldown.",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go modules (minor+patch)",
      "automerge": true
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Pinned scanners in tools.lock: group, automerge after cooldown + a green self-scan.",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["tools.lock"],
      "groupName": "pinned scanners",
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump pinned scanner versions in tools.lock",
      "managerFilePatterns": ["/^tools\\.lock$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+version:\\s*(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "semver"
    }
  ]
}
