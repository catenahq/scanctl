{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(America/Toronto)",
    "helpers:pinGitHubActionDigests"
  ],
  "schedule": ["before 5am"],
  "labels": ["dependencies"],
  "minimumReleaseAge": "7 days",
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "automerge": true,
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go modules (minor+patch)",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["tools.lock"],
      "groupName": "pinned scanners",
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump pinned scanner versions in tools.lock",
      "managerFilePatterns": ["/^tools\\.lock$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+version:\\s*(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "semver"
    }
  ]
}
