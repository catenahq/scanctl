{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gosec",
          "informationUri": "https://github.com/securego/gosec/",
          "rules": [
            { "id": "G401", "name": "Use of weak cryptographic primitive" }
          ]
        }
      },
      "results": [
        {
          "ruleId": "G401",
          "level": "warning",
          "message": { "text": "Use of weak cryptographic primitive" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "internal/hash/md5.go" },
                "region": { "startLine": 12 }
              }
            }
          ]
        }
      ]
    }
  ]
}
